# Copy to .env and fill in real values. .env is gitignored.

# MongoDB Atlas connection string for the read-only catalog.
# Replace USER/PASSWORD/CLUSTER with the credentials you were given.
DB_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/catalog?retryWrites=true&w=majority

# Optional overrides. The script and backend default to the values encoded
# in DB_URL (database "catalog") and the single collection found in it
# ("products"). Set these only if you need to point at a different DB or
# collection.
# DB_NAME=catalog
# COLLECTION_NAME=products
